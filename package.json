{
  "name": "bb",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run website#dev",
    "dev:extension": "vp run extension#dev",
    "dev:daemon": "vp run @bb/daemon#dev",
    "bb": "node packages/cli/dist/index.mjs",
    "bb:dev": "pnpm --silent --filter @kvoon/bb-cli exec tsx src/index.ts",
    "up": "vpx taze -I major",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.3"
}
